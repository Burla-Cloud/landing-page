interface Props {
  name: Name;
  size?: number;
  class?: string;
  label?: string;
}

const { name, size = 16, class: className, label } = Astro.props;
const commonAttrs = {
  width: size,
  height: size,
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": 2,
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  "aria-hidden": label ? undefined : "true",
  role: label ? "img" : undefined,
  "aria-label": label,
  class: className,
};
