---
interface Props {
  body: string;
}

const { body } = Astro.props;

function slugify(text: string): string {
  return text
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");
}

interface OutlineEntry {
  text: string;
  slug: string;
  depth: 2 | 3;
}

const allHeadings: OutlineEntry[] = [];
const lines = (body ?? "").split(/\r?\n/);
let inFence = false;
for (const line of lines) {
  if (/^```/.test(line.trim())) { inFence = !inFence; continue; }
  if (inFence) continue;
  const cleanHeading = (raw: string): string =>
    raw
      .replace(/`([^`]+)`/g, "$1")
      .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
      .replace(/[*_]/g, "")
      .trim();

  const m2 = /^##\s+(.+?)\s*$/.exec(line);
  if (m2) {
    const text = cleanHeading(m2[1]!);
    allHeadings.push({ text, slug: slugify(text), depth: 2 });
    continue;
  }
  const m3 = /^###\s+(.+?)\s*$/.exec(line);
  if (m3) {
    const text = cleanHeading(m3[1]!);
    allHeadings.push({ text, slug: slugify(text), depth: 3 });
  }
}

const hasH2 = allHeadings.some((e) => e.depth === 2);
const outline: OutlineEntry[] = hasH2
  ? allHeadings
  : allHeadings.filter((e) => e.depth === 3).map((e) => ({ ...e, depth: 2 }));
---

{outline.length > 0 && (
  <aside class="outline" aria-label="On this page">
    <div class="outline__heading">On this page</div>
    <ul class="outline__list">
      {outline.map((e) => (
        <li>
          <a class={`outline__link outline__link--h${e.depth}`} href={`#${e.slug}`}>{e.text}</a>
        </li>
      ))}
    </ul>
  </aside>
)}
