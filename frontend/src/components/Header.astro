---
import { withBase } from "../utils/base";
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href={withBase("/")} aria-label="Burla home">
      <span class="brand__mark" aria-hidden="true">
        <img src={withBase("/gitbook-favicon.png")} alt="" />
      </span>
      <span class="brand__name">Burla</span>
    </a>

    <nav class="site-header__center" aria-label="Primary">
      <a class="top-link" href={withBase("/docs/quickstart")}>Quickstart</a>
      <a class="top-link" href={withBase("/docs")}>Docs</a>
      <a class="top-link" href={withBase("/examples")}>Examples</a>
    </nav>

    <nav class="site-header__actions" aria-label="Account">
      <a class="text-link text-link--button" href="https://login.burla.dev/">Sign in</a>
      <a class="btn btn--primary" href="https://login.burla.dev/">Try it now</a>
    </nav>
  </div>
</header>
