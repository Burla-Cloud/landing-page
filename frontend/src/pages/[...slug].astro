---
import { getCollection, render } from "astro:content";
import DocLayout from "../layouts/DocLayout.astro";
import { idToUrl, urlToSlug, loadSidebarTitleByUrl, loadSectionForUrl } from "../utils/summary";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries
    .filter((e) => e.id !== "README")
    .map((entry) => {
      const slug = urlToSlug(idToUrl(entry.id));
      return { params: { slug }, props: { entry } };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const url = idToUrl(entry.id);
const sidebarTitle = loadSidebarTitleByUrl(url);
const section = loadSectionForUrl(url);
const firstH1 = entry.body?.match(/^#\s+(.+?)\s*$/m)?.[1];
const firstH2 = entry.body?.match(/^##\s+(.+?)\s*$/m)?.[1];
const displayTitle = url === "/examples" ? "Examples" : sidebarTitle || firstH1 || firstH2 || entry.id;

const fmDescription = (entry.data as { description?: string })?.description?.trim() || undefined;

const firstPara = entry.body
  ?.split(/\n\n+/)
  .find((block) =>
    block.trim() &&
    !block.startsWith("#") &&
    !block.startsWith("---") &&
    !block.startsWith("{") &&
    !block.startsWith("<") &&
    !block.startsWith("```"),
  );
const description = fmDescription || firstPara?.trim().replace(/\s+/g, " ").slice(0, 200);

const hasFirstH1 = !!firstH1;
---

<DocLayout
  title={displayTitle}
  description={description}
  outlineBody={entry.body}
  hideFirstHeading={hasFirstH1}
  pageHeading={displayTitle}
  pageSubtitle={fmDescription}
  pageSection={section}
>
  <Content />
</DocLayout>
