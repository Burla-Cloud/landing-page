---
import { withBase } from "../utils/base";

const title = "Burla | Scale Python across 1000 CPUs or GPUs in 1 second";
const description =
  "Burla is a high-performance parallel processing library for data teams that iterate quickly. Run vector embeddings, inference, or preprocessing inside your cloud with instant feedback.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <div class="page">
      <div class="hero-atmosphere" aria-hidden="true">
        <span class="hero-atmosphere__mesh"></span>
        <span class="hero-atmosphere__plane hero-atmosphere__plane--one"></span>
        <span class="hero-atmosphere__plane hero-atmosphere__plane--two"></span>
      </div>

      <header class="nav">
        <a class="brand" href={withBase("/")} aria-label="Burla home">
          <img src={withBase("/logo_small.svg")} alt="" />
          <span>Burla</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href={withBase("/get-started")}>Get Started</a>
          <a href={withBase("/api-reference")}>API/CLI Reference</a>
          <a href={withBase("/examples/process-2.4tb-of-parquet-files-in-76s")}>Examples</a>
          <a href="https://github.com/Burla-Cloud/burla" target="_blank" rel="noopener">GitHub</a>
        </nav>
        <div class="nav-actions">
          <a class="nav-signin" href="https://login.burla.dev/">Log In</a>
          <a class="button button--dark button--small" href="https://login.burla.dev/">Try it Now</a>
        </div>
      </header>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <p class="kicker">High-performance parallel processing for data teams</p>
            <h1>Scale Python across 1000 CPUs or GPUs in 1 second.</h1>
            <p class="hero-lede">
              Burla is a high-performance parallel processing library for data-teams that iterate quickly.
              Run vector embeddings, inference, or preprocessing inside your cloud with instant feedback.
            </p>
            <div class="hero-actions">
              <a class="button button--blue" href="https://login.burla.dev/">Try the 1000-CPU Quickstart</a>
              <a class="button button--light" href={withBase("/get-started")}>Self-host with one command</a>
            </div>
          </div>

          <div class="hero-card" aria-label="Burla one-function code example">
            <div class="card-top">
              <span></span><span></span><span></span>
              <strong>remote_parallel_map</strong>
            </div>
            <pre><code><span class="code-purple">from</span> burla <span class="code-purple">import</span> remote_parallel_map

my_inputs = list(range(<span class="code-orange">1000</span>))

<span class="code-purple">def</span> <span class="code-blue">my_function</span>(x):
    print(f<span class="code-green">"[#&#123;x&#125;] running on separate computer"</span>)

remote_parallel_map(my_function, my_inputs)</code></pre>
            <div class="hero-card__footer" aria-hidden="true">
              <div>
                <small>cluster</small>
                <strong>1000 VMs</strong>
              </div>
              <div>
                <small>startup</small>
                <strong>&lt;1 second</strong>
              </div>
              <div>
                <small>cloud</small>
                <strong>your GCP</strong>
              </div>
            </div>
          </div>
        </section>

        <section class="proof-bar" aria-label="Burla proof points">
          <div>
            <strong>1000 VMs</strong>
            <span>in less than one second</span>
          </div>
          <div>
            <strong>10,000 CPUs</strong>
            <span>from a single function call</span>
          </div>
          <div>
            <strong>CPU or GPU</strong>
            <span>per function, per pipeline stage</span>
          </div>
          <div>
            <strong>In your cloud</strong>
            <span>GCP project, containers, and data</span>
          </div>
        </section>

        <section class="terminal-section">
          <div class="section-copy">
            <p class="kicker">Burla only has one function</p>
            <h2>This runs <code>my_function</code> on 1000 VMs in less than one second.</h2>
            <p>
              Keep writing normal Python. Burla handles the cluster, starts workers, syncs code,
              and streams feedback back to the machine where you started the job.
            </p>
          </div>
          <figure class="media-frame media-frame--terminal">
            <img src={withBase("/gitbook-assets/hell_cut_extended_no-zsh.gif")} alt="Terminal running remote_parallel_map across remote machines" />
          </figure>
        </section>

        <section class="pipeline-section">
          <div class="section-heading">
            <p class="kicker">The cleanest way to build data-pipelines that scale.</p>
            <h2>Zero special syntax. Change containers, hardware, or cluster-size automatically mid-workload.</h2>
            <p>
              Burla scales up to 10,000 CPUs in a single function call, supports GPUs, and any Docker container.
              Pipelines built with Burla are simpler, more maintainable, faster, and more fun to develop.
            </p>
          </div>

          <div class="pipeline-grid">
            <div class="pipeline-code">
              <pre><code>remote_parallel_map(process, [...], image=<span class="code-green">"osgeo/gdal:latest"</span>)
remote_parallel_map(aggregate, [...], func_cpu=<span class="code-orange">64</span>)
remote_parallel_map(predict, [...], func_gpu=<span class="code-green">"A100"</span>)</code></pre>
            </div>
            <figure class="media-frame">
              <img src={withBase("/gitbook-assets/data-pipeline-4-high-quality%20(1).gif")} alt="Burla pipeline stages running on different hardware" />
            </figure>
          </div>
        </section>

        <section class="dashboard-section">
          <figure class="media-frame dashboard-media">
            <img src={withBase("/gitbook-assets/area2-radius60-247-251-252.gif")} alt="Burla dashboard showing logs and running jobs" />
          </figure>
          <div class="section-copy">
            <p class="kicker">Monitor progress in the dashboard</p>
            <h2>Cancel bad runs, filter logs to watch individual inputs, or monitor output files in the UI.</h2>
            <p>
              Remote development, local feel. Anything your function prints appears locally and inside the dashboard.
              Any exceptions are thrown locally. Code starts running in under one second, even with millions of inputs or thousands of machines.
            </p>
          </div>
        </section>

        <section class="how-section">
          <div class="section-heading section-heading--split">
            <div>
              <p class="kicker">How it works</p>
              <h2>With Burla hardware is defined where the work happens.</h2>
            </div>
            <div class="mini-code">
              <code>return_values = remote_parallel_map(my_function, my_inputs)</code>
            </div>
          </div>

          <div class="how-grid">
            <article>
              <span>01</span>
              <h3>Anything they print appears locally.</h3>
              <p>Logs also appear inside the dashboard, so every input can be watched without leaving the run.</p>
            </article>
            <article>
              <span>02</span>
              <h3>Any exceptions are thrown locally.</h3>
              <p>Failures keep the same feedback loop as local Python, even while the work is distributed across the cluster.</p>
            </article>
            <article>
              <span>03</span>
              <h3>Packages and local modules are cloned quickly.</h3>
              <p>Burla automatically syncs the code needed on every remote machine where your function is executed.</p>
            </article>
            <article>
              <span>04</span>
              <h3>Code starts running in under one second.</h3>
              <p>The startup path stays fast even with millions of inputs or thousands of machines.</p>
            </article>
          </div>
        </section>

        <section class="features-section">
          <div class="section-heading">
            <p class="kicker">Features</p>
            <h2>Everything needed to move serious data work into elastic cloud hardware.</h2>
          </div>
          <div class="feature-grid">
            <article>
              <div class="feature-icon feature-icon--package" aria-hidden="true"><span></span><span></span><span></span></div>
              <h3>Automatic Package Sync</h3>
              <p>Burla automatically, and very quickly, clones your Python packages on every remote machine where code is executed.</p>
            </article>
            <article>
              <div class="feature-icon feature-icon--container" aria-hidden="true"><span></span><span></span><span></span></div>
              <h3>Custom Containers</h3>
              <p>Easily run code in any Docker container. Public or private, just paste an image URI in the settings, then hit start.</p>
            </article>
            <article>
              <div class="feature-icon feature-icon--filesystem" aria-hidden="true"><span></span><span></span><span></span></div>
              <h3>Network Filesystem</h3>
              <p>Need to get big data into or out of the cluster? Burla automatically mounts a cloud storage bucket to a folder in every container.</p>
            </article>
            <article>
              <div class="feature-icon feature-icon--hardware" aria-hidden="true"><span></span><span></span><span></span></div>
              <h3>Variable Hardware Per-Function</h3>
              <p>The <code>func_cpu</code> and <code>func_ram</code> args make it possible to assign big hardware to some functions, and less to others.</p>
            </article>
          </div>
        </section>

        <section class="pricing-section">
          <div class="section-heading">
            <p class="kicker">Pricing</p>
            <h2>Free for Hobbyists. Compute prices the same as Google Cloud.</h2>
          </div>
          <div class="pricing-grid">
            <article>
              <p class="pricing-label">Self-Hosted</p>
              <h3>In your cloud</h3>
              <strong>$100/month per Enterprise User.</strong>
              <ul>
                <li>Free for all non-commercial use.</li>
                <li>Deploy the self-hosted web-service with <code>burla install</code>.</li>
                <li>Your GCP project, your permissions, your data boundary.</li>
              </ul>
            </article>
            <article>
              <p class="pricing-label">Managed</p>
              <h3>In Burla's cloud</h3>
              <strong>$100/month per Enterprise User.</strong>
              <ul>
                <li>100% identical pricing to Google Cloud.</li>
                <li>$500 in free credits for qualified users.</li>
                <li>Use Google or Microsoft sign-in and start the quickstart in minutes.</li>
              </ul>
            </article>
          </div>
        </section>

        <section class="getting-started">
          <div>
            <p class="kicker">Getting Started</p>
            <h2>Self-host with one command, or try the 1000-CPU quickstart.</h2>
          </div>
          <div class="start-cards">
            <article>
              <h3>Self-Host with one command</h3>
              <p>
                Run <code>burla install</code> to deploy our self-hosted web-service.
                Learn more about permissions and installation in our getting started guide.
              </p>
              <a class="text-link" href={withBase("/get-started")}>Read the getting started guide</a>
            </article>
            <article>
              <h3>Try the 1000-CPU Quickstart, it's free and takes 2 minutes</h3>
              <p>
                Sign in using your Google or Microsoft account. Then run our quickstart in a Google Colab notebook.
              </p>
              <a class="text-link" href="https://colab.research.google.com/drive/1msf0EWJA2wdH4QG5wPX2BncSEr5uVufv?usp=sharing" target="_blank" rel="noopener">
                Open the Colab quickstart
              </a>
            </article>
          </div>
        </section>

        <section class="final-cta">
          <p class="kicker">Questions?</p>
          <h2>Schedule a call, or email jake@burla.dev. We're always happy to talk.</h2>
          <div>
            <a class="button button--blue" href="https://login.burla.dev/">Try it Now</a>
            <a class="button button--light" href="https://cal.com/jakez/burla?user=jakez&duration=30" target="_blank" rel="noopener">Schedule a call</a>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>

<style>
  :root {
    --blue: #635bff;
    --blue-dark: #0a2540;
    --green: #00d66f;
    --text: #0a2540;
    --muted: #425466;
    --subtle: #667085;
    --line: #e6ebf1;
    --line-strong: #d7dee8;
    --surface-soft: #f6f9fc;
    --shadow: 0 24px 70px rgba(50, 50, 93, 0.16);
    --shadow-soft: 0 18px 50px rgba(50, 50, 93, 0.1);
    --font-sans: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--text);
    background: #fff;
    font-family: var(--font-sans);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    overflow-x: hidden;
    background:
      linear-gradient(180deg, rgba(246, 249, 252, 0) 0, #f6f9fc 58%, #fff 100%),
      #fff;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(10, 37, 64, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(10, 37, 64, 0.045) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: linear-gradient(180deg, black 0, transparent 620px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
  }

  code,
  pre {
    font-family: var(--font-mono);
  }

  .page {
    position: relative;
    z-index: 0;
    width: min(100%, 1440px);
    margin: 0 auto;
    overflow: hidden;
  }

  .hero-atmosphere {
    position: absolute;
    top: 54px;
    right: -22px;
    z-index: 0;
    width: 690px;
    height: 560px;
    pointer-events: none;
  }

  .hero-atmosphere::before {
    content: "";
    position: absolute;
    inset: 58px 0 0 80px;
    border-radius: 44px;
    background:
      linear-gradient(135deg, rgba(99, 91, 255, 0.13), rgba(0, 214, 111, 0.14)),
      rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(99, 91, 255, 0.12);
    box-shadow: 0 34px 90px rgba(50, 50, 93, 0.12);
    transform: rotate(-7deg) skewY(-3deg);
  }

  .hero-atmosphere__mesh {
    position: absolute;
    inset: 0;
    border-radius: 52px;
    background:
      radial-gradient(circle at 72% 24%, rgba(0, 212, 255, 0.42), transparent 24%),
      radial-gradient(circle at 34% 72%, rgba(99, 91, 255, 0.26), transparent 28%),
      linear-gradient(135deg, rgba(0, 214, 111, 0.22), rgba(246, 249, 252, 0) 54%);
    opacity: 0.92;
  }

  .hero-atmosphere__mesh::before {
    content: "";
    position: absolute;
    inset: 84px 78px 70px 96px;
    background-image:
      linear-gradient(rgba(10, 37, 64, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(10, 37, 64, 0.08) 1px, transparent 1px);
    background-size: 30px 30px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 76%);
    transform: rotate(-7deg);
  }

  .hero-atmosphere__plane {
    position: absolute;
    width: 230px;
    height: 80px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(99, 91, 255, 0.12);
    box-shadow: 0 20px 60px rgba(50, 50, 93, 0.11);
  }

  .hero-atmosphere__plane--one {
    top: 70px;
    right: 70px;
    transform: rotate(-14deg);
  }

  .hero-atmosphere__plane--two {
    right: 168px;
    bottom: 66px;
    transform: rotate(11deg);
  }

  .nav,
  .hero,
  main > section {
    width: min(1180px, calc(100% - 48px));
    margin-left: auto;
    margin-right: auto;
  }

  .nav {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: 24px;
    min-height: 76px;
  }

  main {
    position: relative;
    z-index: 1;
  }

  .brand,
  .nav-links,
  .nav-actions,
  .hero-actions,
  .card-top,
  .final-cta div {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 10px;
    color: var(--blue-dark);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .brand img {
    width: 36px;
    height: 36px;
  }

  .nav-links {
    gap: 30px;
    justify-content: center;
    color: var(--blue-dark);
    font-size: 14px;
    font-weight: 700;
  }

  .nav-links a {
    opacity: 0.82;
  }

  .nav-links a:hover {
    opacity: 1;
  }

  .nav-actions {
    gap: 14px;
    justify-content: flex-end;
  }

  .nav-signin {
    color: var(--blue-dark);
    font-size: 14px;
    font-weight: 700;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.01em;
    transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button--small {
    min-height: 40px;
    padding: 0 16px;
    font-size: 14px;
  }

  .button--dark {
    color: #fff;
    background: var(--blue-dark);
  }

  .button--blue {
    color: #fff;
    background: var(--blue);
    box-shadow: 0 16px 36px rgba(99, 91, 255, 0.28);
  }

  .button--light {
    color: var(--blue-dark);
    background: #fff;
    border: 1px solid var(--line-strong);
    box-shadow: 0 10px 24px rgba(50, 50, 93, 0.08);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.03fr) minmax(420px, 0.97fr);
    gap: 60px;
    align-items: center;
    min-height: 676px;
    padding: 74px 0 58px;
  }

  .kicker {
    margin: 0 0 18px;
    color: var(--blue);
    font-size: 13px;
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 750px;
    color: var(--blue-dark);
    font-size: clamp(58px, 7.2vw, 94px);
    line-height: 0.95;
    letter-spacing: -0.078em;
  }

  h2 {
    color: var(--blue-dark);
    font-size: clamp(36px, 4.6vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.061em;
  }

  h3 {
    color: var(--blue-dark);
    font-size: 23px;
    line-height: 1.16;
    letter-spacing: -0.04em;
  }

  .hero-lede {
    max-width: 660px;
    margin-top: 26px;
    color: var(--muted);
    font-size: 21px;
    line-height: 1.55;
    letter-spacing: -0.025em;
  }

  .hero-actions {
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .hero-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(10, 37, 64, 0.1);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(10, 37, 64, 0.94), rgba(13, 66, 82, 0.95));
    box-shadow: 0 28px 80px rgba(10, 37, 64, 0.22);
    transform: translateY(20px);
  }

  .hero-card::after {
    content: "";
    position: absolute;
    inset: auto -12% -22% 22%;
    height: 160px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(0, 212, 255, 0.22), rgba(0, 214, 111, 0.18));
    filter: blur(22px);
  }

  .card-top {
    gap: 8px;
    height: 52px;
    padding: 0 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .card-top span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .card-top span:nth-child(1) {
    background: #ff6b84;
  }

  .card-top span:nth-child(2) {
    background: #ffcf5c;
  }

  .card-top span:nth-child(3) {
    background: #5befb7;
  }

  .card-top strong {
    margin-left: auto;
    color: rgba(255, 255, 255, 0.62);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
  }

  pre {
    margin: 0;
    overflow-x: auto;
  }

  .hero-card pre {
    padding: 28px;
    color: #fff;
    font-size: 14px;
    line-height: 1.85;
  }

  .hero-card__footer {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    padding: 1px;
    background: rgba(255, 255, 255, 0.11);
  }

  .hero-card__footer div {
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.055);
  }

  .hero-card__footer small,
  .hero-card__footer strong {
    display: block;
  }

  .hero-card__footer small {
    color: rgba(255, 255, 255, 0.52);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-card__footer strong {
    margin-top: 5px;
    color: #fff;
    font-size: 17px;
    letter-spacing: -0.035em;
  }

  .code-purple {
    color: #c0b8ff;
  }

  .code-blue {
    color: #8bd5ff;
  }

  .code-green {
    color: #7cffbf;
  }

  .code-orange {
    color: #ffd08a;
  }

  .proof-bar {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: stretch;
    gap: 1px;
    overflow: hidden;
    margin-top: -22px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: var(--line);
    box-shadow: var(--shadow-soft);
  }

  .proof-bar div {
    padding: 24px;
    background: rgba(255, 255, 255, 0.92);
  }

  .proof-bar strong {
    display: block;
    color: var(--blue-dark);
    font-size: 24px;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  .proof-bar span {
    display: block;
    margin-top: 6px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.35;
  }

  main > section {
    padding: 96px 0;
  }

  .terminal-section,
  .dashboard-section {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 58px;
    align-items: center;
  }

  .dashboard-section {
    grid-template-columns: 1.05fr 0.95fr;
  }

  .section-copy p:not(.kicker),
  .section-heading p:not(.kicker) {
